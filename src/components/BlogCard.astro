---
interface Props {
  title: string;
  description: string;
  publishDate: Date;
  category: string;
  tags: string[];
  slug: string;
  featured?: boolean;
}

const { title, description, publishDate, category, slug, featured = false } = Astro.props;

const categoryColors: Record<string, string> = {
  'Arquitectura':   '#00BDD4',
  'DevOps':         '#5CB845',
  'IA Generativa':  '#A78BFA',
  'Liderazgo':      '#F5C200',
  'Opinión':        '#F6AD55',
};

const color = categoryColors[category] ?? '#00BDD4';

const formattedDate = publishDate.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a href={`/blog/${slug}`} class={`blog-card ${featured ? 'blog-card--featured' : ''}`} data-category={category}>
  <div class="blog-card-inner">
    <div class="blog-card-meta">
      <span class="blog-card-category" style={`color: ${color}; border-color: ${color}33;`}>{category}</span>
      <span class="blog-card-date">{formattedDate}</span>
    </div>
    <h3 class="blog-card-title">{title}</h3>
    <p class="blog-card-description">{description}</p>
    <span class="blog-card-link">
      Leer artículo
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </span>
  </div>
  <div class="blog-card-accent" style={`background: ${color};`}></div>
</a>

<style>
  .blog-card {
    display: block;
    position: relative;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--r-lg);
    overflow: hidden;
    text-decoration: none;
    transition: border-color var(--ease), transform var(--ease), box-shadow var(--ease);
  }

  .blog-card:hover {
    border-color: var(--color-border-2);
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0, 189, 212, 0.08);
  }

  .blog-card--featured {
    grid-column: 1 / -1;
  }

  .blog-card--featured .blog-card-title {
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
  }

  .blog-card--featured .blog-card-description {
    font-size: 1rem;
    -webkit-line-clamp: 3;
  }

  .blog-card-inner {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    height: 100%;
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .blog-card-category {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.65rem;
    border: 1px solid;
    border-radius: var(--r-full);
  }

  .blog-card-date {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .blog-card-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.3;
    transition: color var(--ease);
  }

  .blog-card:hover .blog-card-title {
    color: var(--color-accent-light);
  }

  .blog-card-description {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex-grow: 1;
  }

  .blog-card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-top: 0.25rem;
    transition: gap var(--ease);
  }

  .blog-card:hover .blog-card-link {
    gap: 0.6rem;
  }

  .blog-card-accent {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    opacity: 0;
    transition: opacity var(--ease);
  }

  .blog-card:hover .blog-card-accent {
    opacity: 1;
  }
</style>

---
import { contact } from "../data/contact";

// El email se codifica en build-time; nunca aparece en texto plano en el HTML.
const encodedEmail = Buffer.from(contact.email).toString("base64");
---

<section class="contact" id="contact">
  <div class="contact-glow"></div>
  <div class="contact-glow contact-glow--secondary"></div>

  <div class="container">
    <div class="contact-inner">

      <div class="reveal">
        <span class="section-label">{contact.label}</span>
        <h2 class="section-title">{contact.title}</h2>
      </div>

      <div class="contact-body">
        {contact.paragraphs.map((p, i) => (
          <p class={`contact-paragraph reveal reveal-delay-${i + 1}`} set:html={p} />
        ))}
      </div>

      <div class="contact-topics reveal reveal-delay-4">
        {contact.topics.map((topic) => (
          <span class="contact-topic">{topic}</span>
        ))}
      </div>

      <div class="contact-cta reveal reveal-delay-4">
        <!-- href y texto se inyectan por JS; el HTML solo contiene Base64 -->
        <a
          id="contact-email-link"
          data-e={encodedEmail}
          class="contact-cta-btn"
          href="#"
          aria-label={contact.cta}
        >
          <span>{contact.cta}</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
        <span id="contact-email-label" class="contact-email-label" aria-hidden="true"></span>
      </div>

    </div>
  </div>
</section>

<script>
  const link = document.getElementById("contact-email-link") as HTMLAnchorElement | null;
  const label = document.getElementById("contact-email-label");
  if (link && label) {
    const email = atob(link.dataset.e ?? "");
    link.href = "mailto:" + email;
    label.textContent = email;
  }
</script>

---
import { sections } from '../data/sections';
import { pageSections, type PageSection } from '../data/pageSections';

const pageNavOrder: PageSection[] = ['experience', 'skills'];
const pageNavItems = pageNavOrder
  .filter((section) => pageSections[section].enabled)
  .map((section) => ({
    slug: section,
    label: pageSections[section].navLabel,
  }));
---

<header class="header" id="header">
  <nav class="container">
    <a href={import.meta.env.BASE_URL} class="logo" aria-label="Inicio">
      <img src={`${import.meta.env.BASE_URL}logo.png`} alt="Logo" class="logo-img" />
    </a>

    <div class="nav-links" id="nav-links">
      {sections.about && <a href={`${import.meta.env.BASE_URL}#about`}>Sobre mí</a>}
      {pageNavItems.map((item) => (
        <a href={`${import.meta.env.BASE_URL}${item.slug}`}>{item.label}</a>
      ))}
      {sections.projects && <a href={`${import.meta.env.BASE_URL}#projects`}>Proyectos</a>}
      {sections.contact && <a href={`${import.meta.env.BASE_URL}#contact`} class="btn-nav">Contactar</a>}
    </div>

    <button class="menu-toggle" id="menu-toggle" aria-label="Abrir menú">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>
</header>

<script>
  const header = document.getElementById('header')!;
  const menuToggle = document.getElementById('menu-toggle')!;
  const navLinks = document.getElementById('nav-links')!;

  // Scroll effect
  window.addEventListener('scroll', () => {
    header.classList.toggle('scrolled', window.scrollY > 20);
  });

  // Mobile menu toggle
  menuToggle.addEventListener('click', () => {
    navLinks.classList.toggle('open');
    menuToggle.classList.toggle('active');
  });

  // Close menu on link click
  navLinks.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      navLinks.classList.remove('open');
      menuToggle.classList.remove('active');
    });
  });
</script>

---
import { sections } from '../data/sections';
import { pageSections, type PageSection } from '../data/pageSections';

const footerPageOrder: PageSection[] = ['experience', 'skills'];
const footerPageItems = footerPageOrder
  .filter((section) => pageSections[section].enabled)
  .map((section) => ({
    slug: section,
    label: pageSections[section].navLabel,
  }));

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <p class="footer-copy">
        © {year} <a href={import.meta.env.BASE_URL}>Pablo Melero Alonso</a>. Construido con
        <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> e impulsado con <strong style="color: var(--color-accent-light); font-weight: 600;">IA</strong> 🤖.
      </p>

      <nav class="footer-links" aria-label="Footer navigation">
        {sections.about && <a href={`${import.meta.env.BASE_URL}#about`}>Sobre mí</a>}
        {footerPageItems.map((item) => (
          <a href={`${import.meta.env.BASE_URL}${item.slug}`}>{item.label}</a>
        ))}
        {sections.blog && <a href={`${import.meta.env.BASE_URL}blog`}>Blog</a>}
        {sections.projects && <a href={`${import.meta.env.BASE_URL}#projects`}>Proyectos</a>}
        {sections.contact && <a href={`${import.meta.env.BASE_URL}contacto`}>Contacto</a>}
      </nav>
    </div>
  </div>
</footer>

---
import { sections } from '../data/sections';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <p class="footer-copy">
        © {year} <a href={import.meta.env.BASE_URL}>Pablo Melero Alonso</a>. Construido con
        <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> e impulsado con <strong style="color: var(--color-accent-light); font-weight: 600;">IA</strong> 🤖.
      </p>

      <nav class="footer-links" aria-label="Footer navigation">
        {sections.about && <a href="#about">Sobre mí</a>}
        {sections.projects && <a href="#projects">Proyectos</a>}
        {sections.experience && <a href="#experience">Experiencia</a>}
        {sections.contact && <a href="#contact">Contacto</a>}
      </nav>
    </div>
  </div>
</footer>

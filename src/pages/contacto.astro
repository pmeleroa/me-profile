---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { contact } from '../data/contact';

const topics = [
  {
    icon: '🏗️',
    title: 'Diseño de plataformas de ingeniería',
    description: 'Arquitectura de sistemas que escalan con los equipos, no contra ellos.',
  },
  {
    icon: '⚙️',
    title: 'Transformación DevOps y Platform Engineering',
    description: 'De silos a flujos. De procesos manuales a plataformas que empoderan.',
  },
  {
    icon: '🗺️',
    title: 'Arquitectura empresarial',
    description: 'Conectar estrategia de negocio con decisiones técnicas que tienen sentido a largo plazo.',
  },
  {
    icon: '🤖',
    title: 'IA generativa en equipos técnicos',
    description: 'Cómo integrar herramientas de IA en flujos de trabajo de ingeniería de forma efectiva.',
  },
  {
    icon: '🧭',
    title: 'Mentoría técnica',
    description: 'Para ingenieros y líderes técnicos que quieren crecer en amplitud y criterio.',
  },
  {
    icon: '🎤',
    title: 'Conferencias y ponencias',
    description: 'Charlas técnicas sobre arquitectura, plataformas e inteligencia artificial.',
  },
];
---

<Layout
  title="Contacto · Pablo Melero Alonso"
  description="Arquitecto tecnológico disponible para consultoría, mentoría técnica, conferencias y colaboraciones en plataformas de ingeniería e IA."
>
  <Header />
  <main>
    <!-- Header section -->
    <section class="contact-hero">
      <div class="container">
        <div class="reveal">
          <span class="section-label">Contacto</span>
          <h1 class="contact-title">Hablemos</h1>
          <p class="contact-subtitle">
            Me interesa trabajar con personas que tienen retos interesantes.
            Si encaja con lo que hago, encontraremos la forma.
          </p>
        </div>
      </div>
    </section>

    <!-- Topics -->
    <section class="topics-section">
      <div class="container">
        <h2 class="topics-heading reveal">¿Para qué contactarme?</h2>
        <div class="topics-grid">
          {topics.map((topic, i) => (
            <div class={`topic-card reveal reveal-delay-${(i % 3) + 1}`}>
              <span class="topic-icon">{topic.icon}</span>
              <h3 class="topic-title">{topic.title}</h3>
              <p class="topic-description">{topic.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Contact channel -->
    <section class="channel-section">
      <div class="container">
        <div class="channel-card reveal">
          <div class="channel-glow"></div>
          <div class="channel-inner">
            <p class="channel-label">La forma más directa</p>
            <div class="channel-email-wrap">
              <span class="channel-email" id="email-display">{contact.email}</span>
              <button class="copy-btn" id="copy-btn" aria-label="Copiar email" title="Copiar al portapapeles">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                </svg>
                <span class="copy-label" id="copy-label">Copiar</span>
              </button>
            </div>
            <div class="channel-actions">
              <a href={`mailto:${contact.email}`} class="btn-cta">
                Escríbeme
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
              <a
                href="https://www.linkedin.com/in/pablo-melero-alonso"
                target="_blank"
                rel="noopener"
                class="btn-secondary"
              >
                LinkedIn
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                  <polyline points="15 3 21 3 21 9"></polyline>
                  <line x1="10" y1="14" x2="21" y2="3"></line>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Socials context -->
    <section class="socials-section">
      <div class="container">
        <h2 class="socials-heading reveal">También estoy aquí</h2>
        <div class="socials-grid reveal reveal-delay-1">
          <a href="https://github.com/pmeleroa" target="_blank" rel="noopener" class="social-card">
            <div class="social-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
              </svg>
            </div>
            <div class="social-info">
              <p class="social-name">GitHub</p>
              <p class="social-desc">Código, experimentos y proyectos abiertos</p>
            </div>
          </a>
          <a href="https://www.linkedin.com/in/pablo-melero-alonso" target="_blank" rel="noopener" class="social-card">
            <div class="social-icon social-icon--linkedin">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </div>
            <div class="social-info">
              <p class="social-name">LinkedIn</p>
              <p class="social-desc">Perfil profesional y artículos de opinión</p>
            </div>
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  const copyBtn = document.getElementById('copy-btn');
  const copyLabel = document.getElementById('copy-label');
  const emailDisplay = document.getElementById('email-display');

  copyBtn?.addEventListener('click', async () => {
    const email = emailDisplay?.textContent?.trim() ?? '';
    try {
      await navigator.clipboard.writeText(email);
      if (copyLabel) copyLabel.textContent = '¡Copiado!';
      copyBtn.classList.add('copied');
      setTimeout(() => {
        if (copyLabel) copyLabel.textContent = 'Copiar';
        copyBtn.classList.remove('copied');
      }, 2000);
    } catch {
      // Fallback silencioso
    }
  });
</script>

<style>
  /* ── Hero ── */
  .contact-hero {
    padding: calc(var(--header-height) + 5rem) 0 4rem;
    text-align: center;
  }

  .contact-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    margin-top: 0.5rem;
    background: linear-gradient(135deg, var(--color-text) 0%, var(--color-accent-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .contact-subtitle {
    margin-top: 1.25rem;
    font-size: 1.15rem;
    color: var(--color-text-muted);
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.7;
  }

  /* ── Topics ── */
  .topics-section {
    padding: 2rem 0 5rem;
  }

  .topics-heading {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 2rem;
    text-align: center;
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .topic-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--r-lg);
    padding: 1.5rem;
    transition: border-color var(--ease), transform var(--ease);
  }

  .topic-card:hover {
    border-color: var(--color-border-2);
    transform: translateY(-2px);
  }

  .topic-icon {
    font-size: 1.75rem;
    display: block;
    margin-bottom: 0.75rem;
  }

  .topic-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
  }

  .topic-description {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* ── Channel ── */
  .channel-section {
    padding: 2rem 0 5rem;
  }

  .channel-card {
    position: relative;
    max-width: 580px;
    margin: 0 auto;
    background: var(--color-surface);
    border: 1px solid var(--color-border-2);
    border-radius: var(--r-lg);
    overflow: hidden;
  }

  .channel-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, var(--color-accent-glow), transparent 70%);
    pointer-events: none;
  }

  .channel-inner {
    position: relative;
    padding: 3rem;
    text-align: center;
  }

  .channel-label {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .channel-email-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .channel-email {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    font-family: var(--font-mono);
  }

  .copy-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--r-full);
    background: transparent;
    color: var(--color-text-muted);
    font-size: 0.78rem;
    cursor: pointer;
    transition: all var(--ease);
  }

  .copy-btn:hover,
  .copy-btn.copied {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-accent-glow);
  }

  .channel-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 2rem;
    background: var(--color-accent);
    color: #000;
    font-weight: 700;
    border-radius: var(--r-full);
    transition: opacity var(--ease), transform var(--ease);
  }

  .btn-cta:hover {
    opacity: 0.85;
    transform: translateY(-2px);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--r-full);
    color: var(--color-text);
    font-weight: 600;
    transition: border-color var(--ease), color var(--ease);
  }

  .btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* ── Socials ── */
  .socials-section {
    padding: 2rem 0 6rem;
  }

  .socials-heading {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .socials-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    max-width: 680px;
    margin: 0 auto;
  }

  .social-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--r-lg);
    padding: 1.25rem 1.5rem;
    transition: border-color var(--ease), transform var(--ease);
  }

  .social-card:hover {
    border-color: var(--color-border-2);
    transform: translateY(-2px);
  }

  .social-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--r-md);
    background: var(--color-surface-2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .social-icon--linkedin {
    color: #0077B5;
  }

  .social-name {
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 0.2rem;
  }

  .social-desc {
    font-size: 0.82rem;
    color: var(--color-text-muted);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .topics-grid {
      grid-template-columns: 1fr;
    }

    .channel-inner {
      padding: 2rem 1.5rem;
    }

    .socials-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .topics-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

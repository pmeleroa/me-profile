---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlogCard from '../../components/BlogCard.astro';
import { sections } from '../../data/sections';

export async function getStaticPaths() {
  if (!sections.blog) return [];
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const related = allPosts
  .filter((p) => p.slug !== post.slug && p.data.category === post.data.category)
  .slice(0, 3);

const categoryColors: Record<string, string> = {
  'Arquitectura':   '#00BDD4',
  'DevOps':         '#5CB845',
  'IA Generativa':  '#A78BFA',
  'Liderazgo':      '#F5C200',
  'Opinión':        '#F6AD55',
};
const categoryColor = categoryColors[post.data.category] ?? '#00BDD4';

const formattedDate = post.data.publishDate.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout
  title={`${post.data.title} · Blog`}
  description={post.data.description}
  image={post.data.image}
>
  <Header />
  <main>
    <!-- Article Header -->
    <header class="article-header">
      <div class="container article-header-inner">
        <div class="article-meta reveal">
          <span class="article-category" style={`color: ${categoryColor}; border-color: ${categoryColor}33;`}>
            {post.data.category}
          </span>
          <span class="article-date">{formattedDate}</span>
        </div>
        <h1 class="article-title reveal reveal-delay-1">{post.data.title}</h1>
        <p class="article-description reveal reveal-delay-2">{post.data.description}</p>

        {post.data.tags.length > 0 && (
          <div class="article-tags reveal reveal-delay-3">
            {post.data.tags.map((tag) => (
              <span class="article-tag">#{tag}</span>
            ))}
          </div>
        )}
      </div>
    </header>

    <!-- Article Content -->
    <article class="article-body">
      <div class="container article-content">
        <Content />
      </div>
    </article>

    <!-- Author bio -->
    <section class="author-section">
      <div class="container">
        <div class="author-card reveal">
          <img src="/avatar.png" alt="Pablo Melero Alonso" class="author-avatar" onerror="this.style.display='none'" />
          <div class="author-info">
            <p class="author-name">Pablo Melero Alonso</p>
            <p class="author-bio">
              Arquitecto tecnológico especializado en plataformas de ingeniería, DevOps y arquitectura empresarial.
              Exploro cómo la IA puede amplificar el trabajo de los equipos técnicos.
            </p>
            <div class="author-links">
              <a href="https://www.linkedin.com/in/pablo-melero-alonso" target="_blank" rel="noopener" class="author-link">LinkedIn</a>
              <a href="https://github.com/pmeleroa" target="_blank" rel="noopener" class="author-link">GitHub</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Related posts -->
    {related.length > 0 && (
      <section class="related-section">
        <div class="container">
          <h2 class="related-title reveal">Artículos relacionados</h2>
          <div class="related-grid">
            {related.map((p) => (
              <BlogCard
                title={p.data.title}
                description={p.data.description}
                publishDate={p.data.publishDate}
                category={p.data.category}
                tags={p.data.tags}
                slug={p.slug}
              />
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class="article-cta">
      <div class="container">
        <div class="article-cta-inner reveal">
          <p class="article-cta-text">¿Te resultó útil? Me interesa saber qué piensas.</p>
          <a href="/contacto" class="btn-primary">Hablemos</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .article-header {
    padding: calc(var(--header-height) + 4rem) 0 3rem;
    border-bottom: 1px solid var(--color-border);
  }

  .article-header-inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  .article-category {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.65rem;
    border: 1px solid;
    border-radius: var(--r-full);
  }

  .article-date {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .article-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .article-description {
    font-size: 1.15rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.25rem;
  }

  .article-tag {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  /* ── Prose styles ── */
  .article-body {
    padding: 4rem 0;
  }

  .article-content {
    max-width: 760px;
    margin: 0 auto;
  }

  .article-content :global(h2) {
    font-size: 1.6rem;
    font-weight: 700;
    margin-top: 3rem;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .article-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .article-content :global(p) {
    margin-bottom: 1.4rem;
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin-bottom: 1.4rem;
    padding-left: 1.5rem;
  }

  .article-content :global(li) {
    margin-bottom: 0.5rem;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .article-content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .article-content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding: 0.75rem 1.25rem;
    margin: 2rem 0;
    background: var(--color-surface);
    border-radius: 0 var(--r-md) var(--r-md) 0;
    font-style: italic;
    color: var(--color-text-muted);
  }

  .article-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: var(--color-surface-2);
    padding: 0.15em 0.4em;
    border-radius: var(--r-sm);
    color: var(--color-accent-light);
  }

  .article-content :global(pre) {
    background: #0d1117;
    border: 1px solid var(--color-border);
    border-radius: var(--r-md);
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .article-content :global(pre code) {
    background: transparent;
    padding: 0;
    color: #e6edf3;
    font-size: 0.9rem;
  }

  .article-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 3rem 0;
  }

  .article-content :global(img) {
    border-radius: var(--r-md);
    margin: 2rem auto;
  }

  /* ── Author ── */
  .author-section {
    padding: 3rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .author-card {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .author-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 2px solid var(--color-border-2);
  }

  .author-name {
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .author-bio {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  .author-links {
    display: flex;
    gap: 1rem;
  }

  .author-link {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-accent);
    transition: opacity var(--ease);
  }

  .author-link:hover {
    opacity: 0.7;
  }

  /* ── Related ── */
  .related-section {
    padding: 4rem 0;
  }

  .related-title {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 2rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  /* ── CTA ── */
  .article-cta {
    padding: 5rem 0;
  }

  .article-cta-inner {
    text-align: center;
    max-width: 480px;
    margin: 0 auto;
  }

  .article-cta-text {
    font-size: 1.2rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 2rem;
    background: var(--color-accent);
    color: #000;
    font-weight: 700;
    border-radius: var(--r-full);
    transition: opacity var(--ease), transform var(--ease);
  }

  .btn-primary:hover {
    opacity: 0.85;
    transform: translateY(-2px);
  }
</style>
